<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.SEND_SMS" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.WRITE_SMS" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.READ_CALL_LOG" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.READ_PHONE_NUMBERS" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.RECEIVE_MMS" />
    <uses-permission android:name="android.permission.SEND_MMS" />
    <uses-permission android:name="android.permission.READ_MMS" />
    <uses-permission android:name="android.permission.WRITE_MMS" />
    <uses-permission android:name="android.permission.BROADCAST_SMS" />
    <uses-permission android:name="android.permission.BROADCAST_WAP_PUSH" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    
    <!-- Call Overlay Permissions -->
    <uses-permission android:name="android.permission.SYSTEM_OVERLAY_WINDOW" />
    <uses-permission android:name="android.permission.ANSWER_PHONE_CALLS" />
    <uses-permission android:name="android.permission.MANAGE_OWN_CALLS" />
    
    <!-- Telephony Feature -->
    <uses-feature android:name="android.hardware.telephony" android:required="true" />

    <application
        android:name=".MessagesApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Messages"
        android:requestLegacyExternalStorage="true"
        tools:targetApi="31">

        <!-- AdMob App ID -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-3940256099942544~3347511713" />

        <!-- LandingActivity (Splash Screen) - LAUNCHER -->
        <activity
            android:name=".ui.splash.LandingActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- LanguageActivity -->
        <activity
            android:name=".ui.language.LanguageActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages" />

        <!-- MainActivity -->
        <activity
            android:name=".ui.main.MainActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages" />

        <!-- DefaultSmsActivity -->
        <activity
            android:name=".ui.defaultsms.DefaultSmsActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages" />

        <!-- ComposeActivity -->
        <activity
            android:name=".ui.compose.ComposeActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <action android:name="android.intent.action.SENDTO" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="sms" />
                <data android:scheme="smsto" />
                <data android:scheme="mms" />
                <data android:scheme="mmsto" />
            </intent-filter>
        </activity>

        <!-- ConversationDetailActivity -->
        <activity
            android:name=".ui.conversation.ConversationDetailActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages"
            android:windowSoftInputMode="adjustResize" />

        <!-- ConversationDetailsActivity -->
        <activity
            android:name=".ui.conversation.ConversationDetailsActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages" />

        <!-- EditQuickResponseActivity -->
        <activity
            android:name=".ui.conversation.EditQuickResponseActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages" />

        <!-- PersonalizeActivity -->
        <activity
            android:name=".ui.personalize.PersonalizeActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages" />

        <!-- ThemesActivity -->
        <activity
            android:name=".ui.personalize.ThemesActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages" />

        <!-- FontSizeActivity -->
        <activity
            android:name=".ui.personalize.FontSizeActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages" />

        <!-- BubbleActivity -->
        <activity
            android:name=".ui.personalize.BubbleActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages" />

        <!-- RingtoneActivity -->
        <activity
            android:name=".ui.personalize.RingtoneActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages" />

        <!-- ContactsActivity -->
        <activity
            android:name=".ui.contacts.ContactsActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages" />

        <!-- SettingsActivity -->
        <activity
            android:name=".ui.settings.SettingsActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages" />

        <!-- SpamBlockActivity -->
        <activity
            android:name=".ui.spam.SpamBlockActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages" />

        <!-- CustomBlockingActivity -->
        <activity
            android:name=".ui.blocking.CustomBlockingActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages" />

        <!-- BlockedConversationsActivity -->
        <activity
            android:name=".ui.blocking.BlockedConversationsActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages" />

        <!-- ConversationSelectionActivity (for blocking) -->
        <activity
            android:name=".ui.blocking.overlay.ConversationSelectionActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages" />
        
        <!-- ConversationSelectionActivity (for custom filters) -->
        <activity
            android:name=".ui.main.ConversationSelectionActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages" />

        <!-- ContactSelectionActivity -->
        <activity
            android:name=".ui.blocking.overlay.ContactSelectionActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages" />

        <!-- PrivateConversationsActivity -->
        <activity
            android:name=".ui.private.PrivateConversationsActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages" />

        <!-- PinActivity -->
        <activity
            android:name=".ui.pin.PinActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages" />

        <!-- SecurityQuestionActivity -->
        <activity
            android:name=".ui.security.SecurityQuestionActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages.Dialog" />

        <!-- ManageAppsActivity -->
        <activity
            android:name=".ui.manageapps.ManageAppsActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages" />

        <!-- ManageAppsDetailActivity -->
        <activity
            android:name=".ui.manageapps.ManageAppsDetailActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages" />

        <!-- ManageAppsCompleteActivity -->
        <activity
            android:name=".ui.manageapps.ManageAppsCompleteActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages" />

        <!-- ScheduledMessagesActivity -->
        <activity
            android:name=".ui.scheduled.ScheduledMessagesActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages" />

        <!-- CallerSettingsActivity -->
        <activity
            android:name=".ui.caller.CallerSettingsActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages" />

        <!-- CallAfterActivity -->
        <activity
            android:name=".ui.caller.CallAfterActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages"
            android:launchMode="singleTop" />

        <!-- StarredActivity -->
        <activity
            android:name=".ui.starred.StarredActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages" />
        
        <!-- ArchiveActivity -->
        <activity
            android:name=".ui.archive.ArchiveActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages" />
        
        <!-- RecycleBinActivity -->
        <activity
            android:name=".ui.recyclebin.RecycleBinActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages" />

        <!-- NotificationsActivity -->
        <activity
            android:name=".ui.notifications.NotificationsActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages" />

        <!-- AdvanceActivity -->
        <activity
            android:name=".ui.advance.AdvanceActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages" />

        <!-- FeedbackActivity -->
        <activity
            android:name=".ui.feedback.FeedbackActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages" />

        <!-- SwipeGesturesActivity -->
        <activity
            android:name=".ui.swipe.SwipeGesturesActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages" />

        <!-- SingleContactSelectionActivity -->
        <activity
            android:name=".ui.blocking.overlay.SingleContactSelectionActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Messages"
            android:launchMode="singleTop" />

        <!-- SMS Receiver -->
        <receiver
            android:name=".receiver.SmsReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter>
                <action android:name="android.provider.Telephony.SMS_DELIVER" />
            </intent-filter>
        </receiver>

        <!-- SMS Sent Receiver -->
        <receiver
            android:name=".receiver.SmsSentReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.quizangomedia.messages.SMS_SENT" />
            </intent-filter>
        </receiver>

        <!-- SMS Delivered Receiver -->
        <receiver
            android:name=".receiver.SmsDeliveredReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.quizangomedia.messages.SMS_DELIVERED" />
            </intent-filter>
        </receiver>

        <!-- MMS Receiver (WAP_PUSH) -->
        <receiver
            android:name=".receiver.MmsReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_WAP_PUSH">
            <intent-filter>
                <action android:name="android.provider.Telephony.WAP_PUSH_DELIVER" />
                <data android:mimeType="application/vnd.wap.mms-message" />
            </intent-filter>
        </receiver>

        <!-- MMS Sent Receiver -->
        <receiver
            android:name=".receiver.MmsSentReceiver"
            android:exported="true"
            android:taskAffinity="com.quizangomedia.messages.MMS_SENT">
            <intent-filter>
                <action android:name="com.quizangomedia.messages.MMS_SENT" />
            </intent-filter>
        </receiver>

        <!-- MMS Received Receiver -->
        <receiver
            android:name=".receiver.MmsReceivedReceiver"
            android:exported="false"
            android:taskAffinity="com.quizangomedia.messages.MMS_RECEIVED">
            <intent-filter>
                <action android:name="com.quizangomedia.messages.MMS_RECEIVED" />
            </intent-filter>
        </receiver>

        <!-- MMS Updated Receiver -->
        <receiver
            android:name=".receiver.MmsUpdatedReceiver"
            android:exported="false"
            android:taskAffinity="com.quizangomedia.messages.MMS_UPDATED">
            <intent-filter>
                <action android:name="com.quizangomedia.messages.MMS_UPDATED" />
            </intent-filter>
        </receiver>

        <!-- Default SMS App Changed Receiver -->
        <receiver
            android:name=".receiver.DefaultSmsChangedReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.provider.Telephony.SMS_DEFAULT_CHANGED" />
            </intent-filter>
        </receiver>

        <!-- Scheduled Message Receiver -->
        <receiver
            android:name=".receiver.ScheduledMessageReceiver"
            android:exported="false" />

        <!-- Notification Action Receiver -->
        <receiver
            android:name=".receiver.NotificationActionReceiver"
            android:exported="false" />

        <!-- Call Receiver -->
        <receiver
            android:name=".receiver.CallReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter android:priority="998">
                <action android:name="android.intent.action.PHONE_STATE" />
            </intent-filter>
        </receiver>

        <!-- Headless SMS Send Service - Required for default SMS app -->
        <service
            android:name=".service.HeadlessSmsSendService"
            android:exported="true"
            android:permission="android.permission.SEND_RESPOND_VIA_MESSAGE"
            android:enabled="true">
            <intent-filter>
                <action android:name="android.intent.action.RESPOND_VIA_MESSAGE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="sms" />
                <data android:scheme="smsto" />
                <data android:scheme="mms" />
                <data android:scheme="mmsto" />
            </intent-filter>
        </service>

        <!-- FileProvider for sharing files -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
