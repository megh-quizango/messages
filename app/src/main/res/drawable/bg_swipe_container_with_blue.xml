<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#E6F0FF" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <!-- Blue part on left for right swipe -->
    <item
        android:id="@+id/bluePart"
        android:left="0dp"
        android:right="0dp"
        android:top="0dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#0C56CF" />
            <corners android:topLeftRadius="12dp" android:bottomLeftRadius="12dp" />
        </shape>
    </item>
</layer-list>

