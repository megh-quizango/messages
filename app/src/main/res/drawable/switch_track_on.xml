<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- Track fill remains white when on -->
    <solid android:color="#FFFFFF" />
    <!-- Border color will be set programmatically based on theme -->
    <stroke
        android:width="2dp"
        android:color="#0C56CF" />
    <corners android:radius="12dp" />
    <size
        android:width="44dp"
        android:height="24dp" />
</shape>
