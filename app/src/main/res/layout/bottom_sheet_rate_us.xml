<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:padding="24dp">

    <!-- Rate Us Icon -->
    <ImageView
        android:id="@+id/imageRateUs"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/rate_us_a"
        android:contentDescription="Rate Us"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Thank you message -->
    <TextView
        android:id="@+id/textThankYou"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Thank you for your support!"
        android:textColor="@color/black"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/imageRateUs"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Sub message -->
    <TextView
        android:id="@+id/textSubMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Your satisfaction makes all of our effort worthwhile:)"
        android:textColor="@color/gray_dark"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/textThankYou"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Stars Container -->
    <LinearLayout
        android:id="@+id/layoutStars"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/textSubMessage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/star1"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_star_outline"
            android:background="@drawable/bg_star_container"
            android:padding="8dp"
            android:contentDescription="Star 1"
            android:clickable="true"
            android:focusable="true"/>

        <ImageView
            android:id="@+id/star2"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_star_outline"
            android:background="@drawable/bg_star_container"
            android:padding="8dp"
            android:contentDescription="Star 2"
            android:clickable="true"
            android:focusable="true"/>

        <ImageView
            android:id="@+id/star3"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_star_outline"
            android:background="@drawable/bg_star_container"
            android:padding="8dp"
            android:contentDescription="Star 3"
            android:clickable="true"
            android:focusable="true"/>

        <ImageView
            android:id="@+id/star4"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_star_outline"
            android:background="@drawable/bg_star_container"
            android:padding="8dp"
            android:contentDescription="Star 4"
            android:clickable="true"
            android:focusable="true"/>

        <ImageView
            android:id="@+id/star5"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_star_outline"
            android:background="@drawable/bg_star_container"
            android:padding="8dp"
            android:contentDescription="Star 5"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

    <!-- Rate Us Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonRateUs"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Rate Us"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#0C56CF"
        android:enabled="false"
        android:alpha="0.5"
        app:cornerRadius="50dp"
        app:layout_constraintTop_toBottomOf="@id/layoutStars"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>

