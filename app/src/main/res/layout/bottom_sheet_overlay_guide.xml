<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_rounded"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="20dp"
    android:paddingBottom="24dp">

    <!-- Safe & Secure Message -->
    <ImageView
        android:id="@+id/iconShield"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@android:drawable/ic_menu_info_details"
        android:tint="#4CAF50"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/textSafeSecure"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="#Message is safe &amp; secure"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:fontFamily="@font/poppins"
        android:layout_marginStart="12dp"
        app:layout_constraintTop_toTopOf="@+id/iconShield"
        app:layout_constraintBottom_toBottomOf="@+id/iconShield"
        app:layout_constraintStart_toEndOf="@+id/iconShield"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- App Icon and Name -->
    <ImageView
        android:id="@+id/iconApp"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/splash_logo"
        android:scaleType="fitCenter"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@+id/iconShield"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/textAppName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="#Message"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        android:fontFamily="@font/poppins"
        android:layout_marginStart="12dp"
        app:layout_constraintTop_toTopOf="@+id/iconApp"
        app:layout_constraintBottom_toBottomOf="@+id/iconApp"
        app:layout_constraintStart_toEndOf="@+id/iconApp"
        app:layout_constraintEnd_toStartOf="@+id/imageToggleGif" />

    <!-- Toggle GIF -->
    <ImageView
        android:id="@+id/imageToggleGif"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:scaleType="fitCenter"
        app:layout_constraintTop_toTopOf="@+id/iconApp"
        app:layout_constraintBottom_toBottomOf="@+id/iconApp"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Instruction Text -->
    <TextView
        android:id="@+id/textInstruction"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Find #Messages and allow permission"
        android:textColor="#666666"
        android:textSize="12sp"
        android:fontFamily="@font/poppins"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@+id/iconApp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

