<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/transparent"
    android:padding="16dp">

    <!-- Top Section: Contact Info and Message -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Profile Picture -->
        <ImageView
            android:id="@+id/imageProfile"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="12dp"
            android:scaleType="centerCrop" />

        <!-- Name and Message -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/textMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="14sp"
                android:textColor="#666666"
                android:maxLines="2"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Chat Bubble Icon -->
        <ImageView
            android:id="@+id/imageChatBubble"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/splash_logo" />
    </LinearLayout>

    <!-- Divider - using TextView instead of View for RemoteViews compatibility -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:background="#E0E0E0" />

    <!-- Action Buttons -->
    <LinearLayout
        android:id="@+id/layoutButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:weightSum="3">

        <!-- Button 1 -->
        <LinearLayout
            android:id="@+id/buttonAction1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="12dp"
            android:background="@drawable/button_action_background"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="4dp"
            android:minHeight="48dp">

            <ImageView
                android:id="@+id/iconAction1"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/textAction1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Button 2 -->
        <LinearLayout
            android:id="@+id/buttonAction2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="12dp"
            android:background="@drawable/button_action_background"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:minHeight="48dp">

            <ImageView
                android:id="@+id/iconAction2"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/textAction2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Button 3 -->
        <LinearLayout
            android:id="@+id/buttonAction3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="12dp"
            android:background="@drawable/button_action_background"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginStart="4dp"
            android:minHeight="48dp">

            <ImageView
                android:id="@+id/iconAction3"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/textAction3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Reply Input removed - using RemoteInput instead for inline reply -->

</LinearLayout>

