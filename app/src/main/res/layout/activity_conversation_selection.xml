<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fitsSystemWindows="false">

    <!-- Toolbar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="@color/white"
        android:fitsSystemWindows="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/buttonBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_back_button"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="@string/gen_activity_conversation_selection_content_description_1"
            android:scaleType="centerInside"
            android:padding="12dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/textTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/gen_activity_conversation_selection_text_2"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="@id/buttonBack"
            app:layout_constraintBottom_toBottomOf="@id/buttonBack"
            app:layout_constraintStart_toEndOf="@id/buttonBack"
            app:layout_constraintEnd_toStartOf="@id/buttonSave"/>

        <TextView
            android:id="@+id/buttonSave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/gen_activity_conversation_selection_text_3"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#0C56CF"
            android:padding="12dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewConversations"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:padding="8dp"
        android:fitsSystemWindows="false"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/layoutEmptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/recyclerViewConversations"
        app:layout_constraintBottom_toBottomOf="@id/recyclerViewConversations"
        app:layout_constraintStart_toStartOf="@id/recyclerViewConversations"
        app:layout_constraintEnd_toEndOf="@id/recyclerViewConversations">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/feedback"
            android:contentDescription="@string/gen_activity_conversation_selection_content_description_4"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/gen_activity_conversation_selection_text_5"
            android:textSize="16sp"
            android:textColor="#9696A3"
            android:gravity="center"/>
    </LinearLayout>

    <!-- Loading State -->
    <LinearLayout
        android:id="@+id/layoutLoadingState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/recyclerViewConversations"
        app:layout_constraintBottom_toBottomOf="@id/recyclerViewConversations"
        app:layout_constraintStart_toStartOf="@id/recyclerViewConversations"
        app:layout_constraintEnd_toEndOf="@id/recyclerViewConversations">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminate="true"
            app:indicatorColor="#0C56CF"
            app:trackColor="#E6F0FF"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/gen_activity_conversation_selection_text_6"
            android:textSize="16sp"
            android:textColor="#9696A3"
            android:gravity="center"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>



