<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- ================= SEARCH BAR ================= -->

    <LinearLayout
        android:id="@+id/searchBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_search_pill"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_menu_search"
            android:tint="#9696A3"/>

        <EditText
            android:id="@+id/editTextSearch"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="Search Messages"
            android:textColorHint="#9696A3"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:imeOptions="actionSearch"/>

        <ImageView
            android:id="@+id/imageViewMenu"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="12dp"
            android:src="@android:drawable/ic_menu_more"
            android:tint="#9696A3"
            android:contentDescription="More options"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

    <!-- ================= CATEGORY TABS (RESTORED) ================= -->

    <HorizontalScrollView
        android:id="@+id/categoryTabs"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/searchBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/layoutTabs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tabAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:text="All"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_tab_selected"/>

            <TextView
                android:id="@+id/tabPersonal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:text="Personal"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:background="@drawable/bg_tab_unselected"/>

            <TextView
                android:id="@+id/tabOTPs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:text="OTPs"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:background="@drawable/bg_tab_unselected"/>

            <TextView
                android:id="@+id/tabOffers"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:text="Offers"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:background="@drawable/bg_tab_unselected"/>

            <TextView
                android:id="@+id/tabTransactions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:text="Transactions"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:background="@drawable/bg_tab_unselected"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- ================= FRAGMENT CONTAINER (for Contacts/Personalize/Settings) ================= -->

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragmentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ================= CONVERSATION LIST ================= -->

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewConversations"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/categoryTabs"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ================= EMPTY STATE ================= -->

    <LinearLayout
        android:id="@+id/layoutEmptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/recyclerViewConversations"
        app:layout_constraintBottom_toBottomOf="@id/recyclerViewConversations"
        app:layout_constraintStart_toStartOf="@id/recyclerViewConversations"
        app:layout_constraintEnd_toEndOf="@id/recyclerViewConversations">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/feedback"
            android:contentDescription="Empty state icon"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/textEmptyState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Message list empty"
            android:textSize="16sp"
            android:textColor="#9696A3"
            android:gravity="center"/>
    </LinearLayout>

    <!-- ================= LOADING INDICATOR ================= -->

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/progressIndicator"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:indeterminate="true"
        android:visibility="gone"
        app:indicatorColor="#0C56CF"
        app:trackColor="#E6F0FF"
        app:layout_constraintTop_toTopOf="@id/recyclerViewConversations"
        app:layout_constraintBottom_toBottomOf="@id/recyclerViewConversations"
        app:layout_constraintStart_toStartOf="@id/recyclerViewConversations"
        app:layout_constraintEnd_toEndOf="@id/recyclerViewConversations"/>

    <!-- ================= BOTTOM NAV ================= -->

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#0C56CF"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:minHeight="0dp"
        style="@style/BottomNavStyle"
        app:itemIconSize="24dp"
        app:itemIconTint="@color/bottom_nav_item_selector"
        app:itemTextColor="@color/bottom_nav_item_selector"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_navigation"
        app:layout_constraintBottom_toTopOf="@id/adViewBanner"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ================= BANNER AD ================= -->

    <com.google.android.gms.ads.AdView
        android:id="@+id/adViewBanner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:adSize="BANNER"
        app:adUnitId="ca-app-pub-3940256099942544/6300978111"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ================= FAB ================= -->

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabStartChat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Start Chat"
        android:textColor="@color/white"
        android:backgroundTint="#0C56CF"
        app:icon="@drawable/start"
        app:iconTint="@color/white"
        app:cornerRadius="80dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationView"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
