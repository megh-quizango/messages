                            android:layout_alignParentEnd="true"
                            android:src="@android:drawable/ic_menu_help"
                            android:tint="@color/white"
                            android:alpha="0.8"/>
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Bling -->
                <com.google.android.material.card.MaterialCardView
