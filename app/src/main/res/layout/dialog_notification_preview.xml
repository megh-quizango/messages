<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="24dp"
    android:background="@drawable/bg_dialog_rounded">

    <!-- Title -->
    <TextView
        android:id="@+id/textTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Notification Previews"
        android:textColor="@color/black"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Show name and message -->
    <RadioButton
        android:id="@+id/radioShowNameAndMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Show name and message"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:buttonTint="#0C56CF"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/textTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Show Name -->
    <RadioButton
        android:id="@+id/radioShowName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Show Name"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:buttonTint="#0C56CF"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/radioShowNameAndMessage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Hide contents -->
    <RadioButton
        android:id="@+id/radioHideContents"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Hide contents"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:buttonTint="#0C56CF"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/radioShowName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>

