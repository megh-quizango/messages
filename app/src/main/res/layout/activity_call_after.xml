<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:id="@+id/stickyTopContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/headerSection"
            android:layout_width="match_parent"
            android:layout_height="88dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:background="@color/primary_blue">

            <TextView
                android:id="@+id/textContactName"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginStart="108dp"
                android:layout_marginEnd="16dp"
                android:ellipsize="end"
                android:fontFamily="@font/poppins"
                android:gravity="center_vertical"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="@string/unknown_number"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@id/callInfoCard"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="Private Number" />

            <ImageView
                android:id="@+id/imageAvatar"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="28dp"
                android:elevation="8dp"
                android:scaleType="fitCenter"
                android:src="@drawable/avatar"
                android:translationZ="8dp"
                app:layout_constraintBottom_toTopOf="@id/callInfoCard"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/callInfoCard" />

            <TextView
                android:id="@+id/textAvatarLetter"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="28dp"
                android:background="@android:color/transparent"
                android:elevation="9dp"
                android:fontFamily="@font/poppins"
                android:gravity="center"
                android:includeFontPadding="false"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:translationZ="9dp"
                android:visibility="gone"
                app:layout_constraintBottom_toTopOf="@id/callInfoCard"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/callInfoCard" />

            <androidx.cardview.widget.CardView
                android:id="@+id/callInfoCard"
                android:layout_width="0dp"
                android:layout_height="46dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="0dp"
                app:cardElevation="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="1.0">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingStart="108dp"
                    android:paddingEnd="16dp">

                    <LinearLayout
                        android:id="@+id/callMetaRow"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/buttonCall"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <TextView
                            android:id="@+id/textCallTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:fontFamily="@font/poppins"
                            android:maxLines="1"
                            android:textColor="@color/black"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            tools:text="Mon, 10:15 PM" />

                        <View
                            android:id="@+id/dotSeparator"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:layout_marginStart="10dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_dot_separator" />

                        <TextView
                            android:id="@+id/textCallStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:fontFamily="@font/poppins"
                            android:maxLines="1"
                            android:textColor="#8D95A5"
                            android:textSize="13sp"
                            tools:text="Incoming 03:24" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/textCallDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        tools:text="03:24" />

                    <ImageButton
                        android:id="@+id/buttonCall"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@android:color/transparent"
                        android:contentDescription="@string/call_action"
                        android:padding="0dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/dialer"
                        android:tag="exclude_from_theme_tint"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:id="@+id/tabBar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/primary_blue"
            android:baselineAligned="false"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:elevation="6dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/tabMessages"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/imageTabMessages"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@string/after_call_tab_messages"
                    android:padding="2dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/q_list" />

                <View
                    android:id="@+id/indicatorTabMessages"
                    android:layout_width="62dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="5dp"
                    android:background="@drawable/bg_after_call_tab_indicator" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tabQuickMessages"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/imageTabQuickMessages"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@string/after_call_tab_quick_messages"
                    android:padding="2dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/q_message" />

                <View
                    android:id="@+id/indicatorTabQuickMessages"
                    android:layout_width="62dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="5dp"
                    android:background="@drawable/bg_after_call_tab_indicator"
                    android:visibility="invisible" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tabReminders"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/imageTabReminders"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@string/after_call_tab_reminders"
                    android:padding="2dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/reminder" />

                <View
                    android:id="@+id/indicatorTabReminders"
                    android:layout_width="62dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="5dp"
                    android:background="@drawable/bg_after_call_tab_indicator"
                    android:visibility="invisible" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tabActions"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/imageTabActions"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@string/after_call_tab_actions"
                    android:padding="2dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/more" />

                <View
                    android:id="@+id/indicatorTabActions"
                    android:layout_width="62dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="5dp"
                    android:background="@drawable/bg_after_call_tab_indicator"
                    android:visibility="invisible" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/contentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/white"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/nativeAdContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/stickyTopContainer">

        <FrameLayout
            android:id="@+id/messagesContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerRecentMessages"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                tools:itemCount="5"
                tools:listitem="@layout/item_after_call_message" />

            <TextView
                android:id="@+id/textMessagesEmpty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/poppins"
                android:text="@string/after_call_no_messages"
                android:textColor="#8D95A5"
                android:textSize="15sp"
                android:visibility="gone" />
        </FrameLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerQuickResponses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingStart="16dp"
            android:paddingTop="18dp"
            android:paddingEnd="16dp"
            android:paddingBottom="112dp"
            android:visibility="gone"
            tools:itemCount="5"
            tools:listitem="@layout/item_quick_response" />

        <ScrollView
            android:id="@+id/remindersContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="never"
            android:paddingBottom="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            <LinearLayout
                android:id="@+id/reminderEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingTop="46dp"
                android:paddingEnd="28dp"
                android:paddingBottom="24dp">

                <ImageView
                    android:id="@+id/imageRemindersEmpty"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:contentDescription="@string/after_call_tab_reminders"
                    android:src="@drawable/no_reminder" />

                <TextView
                    android:id="@+id/textRemindersTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:fontFamily="@font/poppins"
                    android:text="@string/after_call_no_reminders_title"
                    android:textColor="@color/black"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textRemindersSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/poppins"
                    android:gravity="center"
                    android:text="@string/after_call_no_reminders_subtitle"
                    android:textColor="#80889B"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonAddReminder"
                    android:layout_width="wrap_content"
                    android:layout_height="46dp"
                    android:layout_marginTop="24dp"
                    android:backgroundTint="@color/primary_blue"
                    android:fontFamily="@font/poppins"
                    android:paddingStart="22dp"
                    android:paddingEnd="22dp"
                    android:text="@string/after_call_add_reminders"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    app:cornerRadius="10dp"
                    app:icon="@drawable/ic_add"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    app:iconTint="@color/white" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/reminderEditorState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="26dp"
                android:paddingTop="20dp"
                android:paddingEnd="26dp"
                android:paddingBottom="24dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_edit_pencil"
                        app:tint="#5D6470" />

                    <EditText
                        android:id="@+id/editReminderTitle"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:fontFamily="@font/poppins"
                        android:hint="@string/after_call_remind_me_about"
                        android:imeOptions="actionDone"
                        android:inputType="textCapSentences"
                        android:maxLines="1"
                        android:textColor="@color/black"
                        android:textColorHint="#4A4A4A"
                        android:textSize="17sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins"
                        android:text="@string/after_call_reminder_date"
                        android:textColor="#5D6470"
                        android:textSize="13sp" />

                    <NumberPicker
                        android:id="@+id/pickerReminderDay"
                        android:layout_width="match_parent"
                        android:layout_height="86dp"
                        android:layout_marginTop="4dp"
                        android:descendantFocusability="blocksDescendants"
                        android:selectionDividerHeight="1dp" />

                    <LinearLayout
                        android:id="@+id/buttonSelectReminderTime"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="10dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="2dp"
                        android:paddingEnd="2dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_after_call_alarm"
                            app:tint="#5D6470" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/poppins"
                            android:text="@string/after_call_reminder_time"
                            android:textColor="#333333"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/textReminderTimeValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins"
                            android:textColor="@color/primary_blue"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            tools:text="06:15 PM" />
                    </LinearLayout>

                    <NumberPicker
                        android:id="@+id/pickerReminderHour"
                        android:layout_width="66dp"
                        android:layout_height="0dp"
                        android:layout_marginStart="12dp"
                        android:descendantFocusability="blocksDescendants"
                        android:selectionDividerHeight="1dp"
                        android:visibility="gone" />

                    <NumberPicker
                        android:id="@+id/pickerReminderMinute"
                        android:layout_width="66dp"
                        android:layout_height="0dp"
                        android:layout_marginStart="10dp"
                        android:descendantFocusability="blocksDescendants"
                        android:selectionDividerHeight="1dp"
                        android:visibility="gone" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/reminderColorRow"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:layout_marginTop="14dp"
                    android:gravity="center"
                    android:orientation="horizontal" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonCancelReminder"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="18dp"
                        android:layout_weight="1"
                        android:backgroundTint="#D1D1D1"
                        android:fontFamily="@font/poppins"
                        android:text="@string/action_cancel"
                        android:textAllCaps="false"
                        android:textColor="@color/black"
                        android:textSize="15sp"
                        app:cornerRadius="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonSaveReminder"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:backgroundTint="@color/primary_blue"
                        android:fontFamily="@font/poppins"
                        android:text="@string/save"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        app:cornerRadius="8dp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/reminderSavedState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="24dp"
                android:paddingEnd="20dp"
                android:paddingBottom="12dp"
                android:visibility="gone">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="72dp">

                    <View
                        android:id="@+id/savedReminderColorDot"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_unread_dot"
                        app:layout_constraintBottom_toBottomOf="@id/textSavedReminderTitle"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="@id/textSavedReminderTitle" />

                    <TextView
                        android:id="@+id/textSavedReminderTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="18dp"
                        android:layout_marginEnd="10dp"
                        android:ellipsize="end"
                        android:fontFamily="@font/poppins"
                        android:maxLines="1"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@id/buttonEditReminder"
                        app:layout_constraintStart_toEndOf="@id/savedReminderColorDot"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:text="Evening Walk" />

                    <LinearLayout
                        android:id="@+id/savedReminderMetaRow"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="18dp"
                        android:layout_marginTop="6dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        app:layout_constraintEnd_toStartOf="@id/buttonEditReminder"
                        app:layout_constraintStart_toEndOf="@id/savedReminderColorDot"
                        app:layout_constraintTop_toBottomOf="@id/textSavedReminderTitle">

                        <ImageView
                            android:layout_width="19dp"
                            android:layout_height="19dp"
                            android:src="@drawable/ic_after_call_alarm"
                            app:tint="#666666" />

                        <TextView
                            android:id="@+id/textSavedReminderTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:fontFamily="@font/poppins"
                            android:textColor="#666666"
                            android:textSize="14sp"
                            tools:text="06:15" />

                        <ImageView
                            android:layout_width="19dp"
                            android:layout_height="19dp"
                            android:layout_marginStart="18dp"
                            android:src="@drawable/ic_after_call_calendar"
                            app:tint="#666666" />

                        <TextView
                            android:id="@+id/textSavedReminderDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:fontFamily="@font/poppins"
                            android:textColor="#666666"
                            android:textSize="14sp"
                            tools:text="Today" />
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/buttonEditReminder"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/edit"
                        android:padding="6dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/r_edit"
                        app:layout_constraintEnd_toStartOf="@id/buttonDeleteReminder"
                        app:layout_constraintTop_toTopOf="@id/textSavedReminderTitle" />

                    <ImageButton
                        android:id="@+id/buttonDeleteReminder"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/delete"
                        android:padding="6dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/r_delete"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/textSavedReminderTitle" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:background="#E0E0E0" />
            </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerQuickActions"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingStart="18dp"
            android:paddingTop="14dp"
            android:paddingEnd="18dp"
            android:paddingBottom="24dp"
            android:visibility="gone"
            tools:itemCount="9"
            tools:listitem="@layout/item_after_call_action" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/nativeAdContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="0dp"
        android:background="@drawable/bg_ad_container_full_bleed"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:elevation="10dp"
        android:minHeight="220dp"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/adLoadingPlaceholder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="24dp"
            android:visibility="visible">

            <ProgressBar
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:indeterminateTint="@color/primary_blue" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/loading_ad"
                android:textColor="@color/gray_dark"
                android:textSize="12sp" />
        </LinearLayout>

        <com.google.android.gms.ads.nativead.NativeAdView
            android:id="@+id/nativeAdView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="8dp">

                <TextView
                    android:id="@+id/adBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_ad_badge"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:text="@string/ad"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.gms.ads.nativead.MediaView
                    android:id="@+id/adMedia"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="4dp"
                    app:layout_constraintDimensionRatio="H,16:9"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/adBadge" />

                <ImageView
                    android:id="@+id/adIcon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_rounded_icon"
                    android:contentDescription="@string/ad_icon"
                    android:scaleType="centerCrop"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/adMedia" />

                <TextView
                    android:id="@+id/adHeadline"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="8dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/adIcon"
                    app:layout_constraintEnd_toStartOf="@id/adCta"
                    app:layout_constraintStart_toEndOf="@id/adIcon"
                    app:layout_constraintTop_toTopOf="@id/adIcon"
                    tools:text="Ad Headline Here" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/adCta"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:backgroundTint="@color/primary_blue"
                    android:paddingHorizontal="16dp"
                    android:text="@string/open"
                    android:textAllCaps="true"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:cornerRadius="20dp"
                    app:layout_constraintBottom_toBottomOf="@id/adIcon"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/adIcon" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.gms.ads.nativead.NativeAdView>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
