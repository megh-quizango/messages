<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingHorizontal="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="24dp"
    android:background="@color/white">

        <!-- ================= TOP CONTACT HEADER SECTION ================= -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/headerSection"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:paddingVertical="10dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- LEFT: Circular Avatar Container -->
            <FrameLayout
                android:id="@+id/avatarContainer"
                android:layout_width="64dp"
                android:layout_height="64dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/imageAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_person_white"
                    android:elevation="0dp"
                    android:outlineProvider="none" />

                <TextView
                    android:id="@+id/textAvatarLetter"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text=""
                    android:textColor="@color/gray_dark"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    android:elevation="0dp"
                    android:background="@android:color/transparent"
                    android:includeFontPadding="false"
                    android:textAlignment="center" />
            </FrameLayout>

            <!-- CENTER: Contact Info -->
            <LinearLayout
                android:id="@+id/contactInfoContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="12dp"
                android:orientation="vertical"
                app:layout_constraintStart_toEndOf="@id/avatarContainer"
                app:layout_constraintEnd_toStartOf="@id/imageLogo"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <!-- Contact Name -->
                <TextView
                    android:id="@+id/textContactName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/unknown_number"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    tools:text="John Doe" />

                <!-- Call Time & Status Row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/textCallTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/gray_dark"
                        android:textSize="13sp"
                        tools:text="05:03 pm" />

                    <View
                        android:id="@+id/dotSeparator"
                        android:layout_width="4dp"
                        android:layout_height="4dp"
                        android:layout_marginHorizontal="8dp"
                        android:background="@drawable/bg_dot_separator" />

                    <TextView
                        android:id="@+id/textCallStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/gray_dark"
                        android:textSize="13sp"
                        tools:text="No answer" />
                </LinearLayout>

                <!-- Call Duration -->
                <TextView
                    android:id="@+id/textCallDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/gray_dark"
                    android:textSize="13sp"
                    android:visibility="gone"
                    tools:text="00:24" />
            </LinearLayout>

            <!-- RIGHT: App Logo -->
            <ImageView
                android:id="@+id/imageLogo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/splash_logo"
                android:contentDescription="@string/app_name"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

<!--        &lt;!&ndash; DIVIDER 1 &ndash;&gt;-->
<!--        <View-->
<!--            android:id="@+id/divider1"-->
<!--            android:layout_width="0dp"-->
<!--            android:layout_height="1dp"-->
<!--            android:layout_marginTop="12dp"-->
<!--            android:background="#E0E0E0"-->
<!--            app:layout_constraintTop_toBottomOf="@id/headerSection"-->
<!--            app:layout_constraintStart_toStartOf="parent"-->
<!--            app:layout_constraintEnd_toEndOf="parent" />-->

        <!-- ================= ACTION BUTTON BAR ================= -->
        <LinearLayout
            android:id="@+id/actionButtonBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:weightSum="3"
            app:layout_constraintTop_toBottomOf="@id/headerSection"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- CALL Button -->
            <LinearLayout
                android:id="@+id/buttonCall"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="0dp"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:paddingHorizontal="8dp"
                android:background="@drawable/bg_action_button_unselected"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/iconCall"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_call"
                    app:tint="@color/primary_blue" />

                <TextView
                    android:id="@+id/textCallLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/call_action"
                    android:textColor="@color/primary_blue"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- MESSAGE Button -->
            <LinearLayout
                android:id="@+id/buttonMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="0dp"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:paddingHorizontal="8dp"
                android:background="@drawable/bg_action_button_selected"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/iconMessage"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_chat_bubble"
                    app:tint="@color/white" />

                <TextView
                    android:id="@+id/textMessageLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/message_action"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- ADD CONTACT Button -->
            <LinearLayout
                android:id="@+id/buttonAddContact"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="0dp"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:paddingHorizontal="8dp"
                android:background="@drawable/bg_action_button_unselected"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/iconAddContact"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_person_add"
                    app:tint="@color/primary_blue" />

                <TextView
                    android:id="@+id/textAddContactLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/add_contact_action"
                    android:textColor="@color/primary_blue"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

<!--        &lt;!&ndash; DIVIDER 2 &ndash;&gt;-->
<!--        <View-->
<!--            android:id="@+id/divider2"-->
<!--            android:layout_width="0dp"-->
<!--            android:layout_height="1dp"-->
<!--            android:layout_marginTop="16dp"-->
<!--            android:background="#E0E0E0"-->
<!--            app:layout_constraintTop_toBottomOf="@id/actionButtonBar"-->
<!--            app:layout_constraintStart_toStartOf="parent"-->
<!--            app:layout_constraintEnd_toEndOf="parent" />-->

        <!-- ================= QUICK RESPONSE SECTION ================= -->
        <TextView
            android:id="@+id/textQuickResponseTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/quick_responses"
            android:textColor="@color/black"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/actionButtonBar"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- QUICK RESPONSE LIST (RecyclerView) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerQuickResponses"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:nestedScrollingEnabled="false"
            android:overScrollMode="never"
            app:layout_constraintTop_toBottomOf="@id/textQuickResponseTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:itemCount="3"
            tools:listitem="@layout/item_quick_response" />

        <!-- ================= MESSAGE INPUT FIELD ================= -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/messageInputContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_message_input"
            android:padding="4dp"
            app:layout_constraintTop_toBottomOf="@id/recyclerQuickResponses"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/editMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:background="@android:color/transparent"
                android:hint="@string/write_personal_message"
                android:textColorHint="@color/gray_dark"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:paddingStart="12dp"
                android:paddingEnd="8dp"
                android:paddingVertical="12dp"
                android:inputType="textMultiLine|textCapSentences"
                android:maxLines="3"
                android:imeOptions="actionSend"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/buttonSend"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <ImageButton
                android:id="@+id/buttonSend"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/bg_send_button"
                android:src="@drawable/ic_edit_pencil"
                android:contentDescription="@string/send"
                android:padding="10dp"
                android:scaleType="centerInside"
                app:tint="@color/primary_blue"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ================= NATIVE AD SECTION ================= -->
        <FrameLayout
            android:id="@+id/nativeAdContainer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_ad_container"
            android:visibility="visible"
            app:layout_constraintTop_toBottomOf="@id/messageInputContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- Shimmer/Loading Placeholder -->
            <LinearLayout
                android:id="@+id/adLoadingPlaceholder"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp"
                android:visibility="visible">

                <ProgressBar
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:indeterminateTint="@color/primary_blue" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/loading_ad"
                    android:textColor="@color/gray_dark"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Native Ad View -->
            <com.google.android.gms.ads.nativead.NativeAdView
                android:id="@+id/nativeAdView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">

                    <!-- Ad Badge -->
                    <TextView
                        android:id="@+id/adBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ad"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_ad_badge"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="2dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <!-- Ad Media (Large Image) -->
                    <com.google.android.gms.ads.nativead.MediaView
                        android:id="@+id/adMedia"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_marginTop="8dp"
                        app:layout_constraintDimensionRatio="H,16:9"
                        app:layout_constraintTop_toBottomOf="@id/adBadge"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <!-- Ad Icon -->
                    <ImageView
                        android:id="@+id/adIcon"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginTop="12dp"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_rounded_icon"
                        android:contentDescription="@string/ad_icon"
                        app:layout_constraintTop_toBottomOf="@id/adMedia"
                        app:layout_constraintStart_toStartOf="parent" />

                    <!-- Ad Headline -->
                    <TextView
                        android:id="@+id/adHeadline"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_marginEnd="8dp"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:maxLines="2"
                        android:ellipsize="end"
                        tools:text="Ad Headline Here"
                        app:layout_constraintTop_toTopOf="@id/adIcon"
                        app:layout_constraintBottom_toBottomOf="@id/adIcon"
                        app:layout_constraintStart_toEndOf="@id/adIcon"
                        app:layout_constraintEnd_toStartOf="@id/adCta" />

                    <!-- Ad CTA Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/adCta"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="@string/open"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textAllCaps="true"
                        android:textStyle="bold"
                        android:backgroundTint="@color/primary_blue"
                        android:paddingHorizontal="16dp"
                        app:cornerRadius="20dp"
                        app:layout_constraintTop_toTopOf="@id/adIcon"
                        app:layout_constraintBottom_toBottomOf="@id/adIcon"
                        app:layout_constraintEnd_toEndOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.gms.ads.nativead.NativeAdView>

        </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
