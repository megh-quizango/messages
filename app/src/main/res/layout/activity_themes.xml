<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- ================= BACK BUTTON ================= -->

    <ImageButton
        android:id="@+id/buttonBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_back_button"
        android:src="@drawable/ic_arrow_back"
        android:contentDescription="@string/gen_activity_themes_content_description_1"
        android:scaleType="centerInside"
        android:padding="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- ================= HEADING ================= -->

    <TextView
        android:id="@+id/textHeading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="@string/gen_activity_themes_text_2"
        android:textColor="@color/black"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/buttonBack"
        app:layout_constraintBottom_toBottomOf="@id/buttonBack"
        app:layout_constraintStart_toEndOf="@id/buttonBack"/>

    <!-- ================= CLASSICS SECTION ================= -->

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/buttonBack"
        app:layout_constraintBottom_toTopOf="@id/buttonSave"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Classics Section Title -->
            <TextView
                android:id="@+id/textClassicsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/gen_activity_themes_text_3"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <!-- 3x4 Grid of Color Cards -->
            <LinearLayout
                android:id="@+id/gridLayoutClassics"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:weightSum="4">

                <!-- Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <!-- Blue -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardThemeBlue"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_margin="8dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#2196F3"
                        app:cardElevation="2dp"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:id="@+id/iconSelectedBlue"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_check_circle"
                                android:visibility="gone"
                                android:tint="@color/white"/>
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Green -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardThemeGreen"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_margin="8dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#4CAF50"
                        app:cardElevation="2dp"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:id="@+id/iconSelectedGreen"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_check_circle"
                                android:visibility="visible"
                                android:tint="@color/white"/>
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Pink -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardThemePink"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_margin="8dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#E91E63"
                        app:cardElevation="2dp"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:id="@+id/iconSelectedPink"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_check_circle"
                                android:visibility="gone"
                                android:tint="@color/white"/>
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <!-- Yellow -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardThemeYellow"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_margin="8dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#FFEB3B"
                        app:cardElevation="2dp"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:id="@+id/iconSelectedYellow"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_check_circle"
                                android:visibility="gone"
                                android:tint="@color/white"/>
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Oral (Coral/Orange-Red) -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardThemeOral"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_margin="8dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#FF6B6B"
                        app:cardElevation="2dp"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:id="@+id/iconSelectedOral"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_check_circle"
                                android:visibility="gone"
                                android:tint="@color/white"/>
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Navy Blue -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardThemeNavyBlue"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_margin="8dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#1976D2"
                        app:cardElevation="2dp"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:id="@+id/iconSelectedNavyBlue"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_check_circle"
                                android:visibility="gone"
                                android:tint="@color/white"/>
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Row 3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <!-- Cerulean Blue -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardThemeCeruleanBlue"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_margin="8dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#03A9F4"
                        app:cardElevation="2dp"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:id="@+id/iconSelectedCeruleanBlue"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_check_circle"
                                android:visibility="gone"
                                android:tint="@color/white"/>
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Black & Blue -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardThemeBlackBlue"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_margin="8dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#000000"
                        app:cardElevation="2dp"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:id="@+id/iconSelectedBlackBlue"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_check_circle"
                                android:visibility="gone"
                                android:tint="@color/white"/>
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Purple -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardThemePurple"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_margin="8dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#9C27B0"
                        app:cardElevation="2dp"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:id="@+id/iconSelectedPurple"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_check_circle"
                                android:visibility="gone"
                                android:tint="@color/white"/>
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Row 4 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <!-- Teal -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardThemeTeal"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_margin="8dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#009688"
                        app:cardElevation="2dp"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:id="@+id/iconSelectedTeal"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_check_circle"
                                android:visibility="gone"
                                android:tint="@color/white"/>
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Orange -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardThemeOrange"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_margin="8dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#FF9800"
                        app:cardElevation="2dp"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:id="@+id/iconSelectedOrange"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_check_circle"
                                android:visibility="gone"
                                android:tint="@color/white"/>
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Red -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardThemeRed"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_margin="8dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#F44336"
                        app:cardElevation="2dp"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:id="@+id/iconSelectedRed"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_check_circle"
                                android:visibility="gone"
                                android:tint="@color/white"/>
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <Button
        android:id="@+id/buttonSave"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_pill_button"
        android:padding="16dp"
        android:text="@string/save"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>




