<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_rounded_white"
    android:padding="8dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="2dp">

    <!-- OTP Label -->
    <TextView
        android:id="@+id/textOtpLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/gen_layout_otp_box_text_1"
        android:textSize="11sp"
        android:textColor="@color/gray_dark"
        android:layout_marginBottom="4dp" />

    <!-- OTP Value -->
    <TextView
        android:id="@+id/textOtpValue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:layout_marginBottom="8dp"
        android:singleLine="true"
        android:ellipsize="none"
        android:maxLines="1"
        android:minWidth="120dp" />

    <!-- Action Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Copy OTP Button -->
        <TextView
            android:id="@+id/buttonCopyOtp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/gen_layout_otp_box_text_2"
            android:textSize="12sp"
            android:textColor="@color/black"
            android:background="@drawable/button_copy_otp_background"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center" />

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Delete Icon -->
        <ImageView
            android:id="@+id/imageDeleteOtp"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_delete"
            android:tint="@color/gray_dark"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp"
            android:contentDescription="@string/gen_layout_otp_box_content_description_3" />

    </LinearLayout>

</LinearLayout>




