<?xml version="1.0" encoding="utf-8"?>
<com.google.android.gms.ads.nativead.NativeAdView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nativeAdView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fitsSystemWindows="true">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true">

        <!-- Full-screen MediaView for Video -->
        <com.google.android.gms.ads.nativead.MediaView
            android:id="@+id/adMediaView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center" />

        <!-- Segmented Video Progress Bar at very top -->
        <LinearLayout
            android:id="@+id/progressBarContainer"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_gravity="top"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp">

            <!-- First segment (first ad) -->
            <ProgressBar
                android:id="@+id/progressBarSegment1"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/video_progress_drawable"
                android:background="#40FFFFFF" />

            <!-- Gap between segments -->
            <View
                android:id="@+id/progressBarGap"
                android:layout_width="6dp"
                android:layout_height="match_parent"
                android:background="@android:color/transparent" />

            <!-- Second segment (second ad) -->
            <ProgressBar
                android:id="@+id/progressBarSegment2"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/video_progress_drawable"
                android:background="#40FFFFFF" />

        </LinearLayout>

        <!-- Top overlay: Ad badge and close button -->
        <LinearLayout
            android:id="@+id/topOverlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="24dp"
            android:gravity="center_vertical"
            android:background="@drawable/gradient_top_shadow">

            <!-- Ad Label -->
            <TextView
                android:id="@+id/adLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ad"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="#CC0C56CF"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp" />

            <!-- Ad Counter (shows which ad is playing) -->
            <TextView
                android:id="@+id/adCounter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1/2"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="#80000000"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:layout_marginStart="8dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Close Button (only visible for last ad) -->
            <ImageView
                android:id="@+id/adCloseButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:background="#80000000"
                android:padding="8dp"
                android:contentDescription="Close ad"
                android:visibility="gone"
                app:tint="@color/white" />

        </LinearLayout>

        <!-- Bottom overlay: Ad info and CTA -->
        <LinearLayout
            android:id="@+id/bottomOverlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="16dp"
            android:background="@drawable/gradient_bottom_shadow">

            <!-- App Icon and Headline -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/adAppIcon"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_rounded_icon" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/adHeadline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/adBody"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#CCFFFFFF"
                        android:textSize="13sp"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Call to Action Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/adCallToAction"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:text="Install"
                android:textAllCaps="true"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="#0C56CF"
                app:cornerRadius="26dp" />

        </LinearLayout>

    </FrameLayout>

</com.google.android.gms.ads.nativead.NativeAdView>
