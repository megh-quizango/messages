<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- ================= BACK BUTTON ================= -->

    <ImageButton
        android:id="@+id/buttonBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_back_button"
        android:src="@drawable/ic_arrow_back"
        android:contentDescription="Back"
        android:scaleType="centerInside"
        android:padding="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- ================= HEADING ================= -->

    <TextView
        android:id="@+id/textHeading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Bubble"
        android:textColor="@color/black"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/buttonBack"
        app:layout_constraintBottom_toBottomOf="@id/buttonBack"
        app:layout_constraintStart_toEndOf="@id/buttonBack"/>

    <!-- ================= SCROLLABLE CONTENT ================= -->

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/buttonBack"
        app:layout_constraintBottom_toTopOf="@id/buttonApply"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Chat Preview Container -->
            <LinearLayout
                android:id="@+id/layoutChatPreview"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:orientation="vertical"
                android:background="@color/white"
                android:padding="16dp"
                android:layout_marginBottom="24dp"
                android:elevation="2dp">

                <!-- Received Message Bubble -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/textReceivedMessage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chat_bubble_received"
                        android:padding="12dp"
                        android:text="Tap the button below to change message font. Font in your incoming messages will change too!"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:maxWidth="280dp"/>
                </LinearLayout>

                <!-- Sent Message Bubble -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="end">

                    <TextView
                        android:id="@+id/textSentMessage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chat_bubble_sent"
                        android:padding="12dp"
                        android:text="It's Great, I will try it right now!"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:maxWidth="280dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Color Selection Grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <!-- Color Circle 1 - Light Blue -->
                    <FrameLayout
                        android:id="@+id/colorCircle1"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_marginEnd="16dp"
                        android:clickable="true"
                        android:focusable="true">

                        <View
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_color_circle"
                            android:backgroundTint="#B3E5FC"/>

                        <ImageView
                            android:id="@+id/iconSelected1"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_check_circle"
                            android:visibility="visible"
                            android:tint="#4CAF50"/>
                    </FrameLayout>

                    <!-- Color Circle 2 - Light Purple -->
                    <FrameLayout
                        android:id="@+id/colorCircle2"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_marginEnd="16dp"
                        android:clickable="true"
                        android:focusable="true">

                        <View
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_color_circle"
                            android:backgroundTint="#CE93D8"/>

                        <ImageView
                            android:id="@+id/iconSelected2"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_check_circle"
                            android:visibility="gone"
                            android:tint="#4CAF50"/>
                    </FrameLayout>

                    <!-- Color Circle 3 - Light Green -->
                    <FrameLayout
                        android:id="@+id/colorCircle3"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_marginEnd="16dp"
                        android:clickable="true"
                        android:focusable="true">

                        <View
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_color_circle"
                            android:backgroundTint="#C5E1A5"/>

                        <ImageView
                            android:id="@+id/iconSelected3"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_check_circle"
                            android:visibility="gone"
                            android:tint="#4CAF50"/>
                    </FrameLayout>

                    <!-- Color Circle 4 - Light Orange -->
                    <FrameLayout
                        android:id="@+id/colorCircle4"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_marginEnd="16dp"
                        android:clickable="true"
                        android:focusable="true">

                        <View
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_color_circle"
                            android:backgroundTint="#FFCC80"/>

                        <ImageView
                            android:id="@+id/iconSelected4"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_check_circle"
                            android:visibility="gone"
                            android:tint="#4CAF50"/>
                    </FrameLayout>

                    <!-- Color Circle 5 - Light Yellow -->
                    <FrameLayout
                        android:id="@+id/colorCircle5"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:clickable="true"
                        android:focusable="true">

                        <View
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_color_circle"
                            android:backgroundTint="#FFF59D"/>

                        <ImageView
                            android:id="@+id/iconSelected5"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_check_circle"
                            android:visibility="gone"
                            android:tint="#4CAF50"/>
                    </FrameLayout>
                </LinearLayout>

                <!-- Second Row of Colors -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Color Circle 6 - Light Gray -->
                    <FrameLayout
                        android:id="@+id/colorCircle6"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:clickable="true"
                        android:focusable="true">

                        <View
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_color_circle"
                            android:backgroundTint="#E0E0E0"/>

                        <ImageView
                            android:id="@+id/iconSelected6"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_check_circle"
                            android:visibility="gone"
                            android:tint="#4CAF50"/>
                    </FrameLayout>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ================= APPLY BUTTON ================= -->

    <Button
        android:id="@+id/buttonApply"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:text="Apply"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/bg_pill_button"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>

