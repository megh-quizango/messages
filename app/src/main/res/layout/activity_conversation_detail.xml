<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fitsSystemWindows="false">

    <!-- ================= HEADER (Normal Mode) ================= -->
    <ImageButton
        android:id="@+id/buttonBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_back_button"
        android:src="@drawable/ic_arrow_back"
        android:contentDescription="@string/gen_activity_conversation_detail_content_description_1"
        android:scaleType="centerInside"
        android:padding="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/textContactName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        android:text="@string/gen_activity_conversation_detail_text_2"
        android:textColor="@color/black"
        android:textSize="20sp"
        android:textStyle="bold"
        android:ellipsize="end"
        android:maxLines="1"
        app:layout_constraintTop_toTopOf="@id/buttonBack"
        app:layout_constraintBottom_toBottomOf="@id/buttonBack"
        app:layout_constraintStart_toEndOf="@id/buttonBack"
        app:layout_constraintEnd_toStartOf="@id/imageCall"/>

    <ImageButton
        android:id="@+id/imageCall"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="8dp"
        android:src="@drawable/ic_call"
        android:background="@android:color/transparent"
        android:contentDescription="@string/gen_activity_conversation_detail_content_description_3"
        android:scaleType="centerInside"
        android:padding="12dp"
        app:tint="@color/black"
        app:layout_constraintTop_toTopOf="@id/buttonBack"
        app:layout_constraintBottom_toBottomOf="@id/buttonBack"
        app:layout_constraintEnd_toStartOf="@id/imageInfo"/>

    <ImageButton
        android:id="@+id/imageInfo"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="16dp"
        android:src="@drawable/ic_info"
        android:background="@android:color/transparent"
        android:contentDescription="@string/gen_activity_conversation_detail_content_description_4"
        android:scaleType="centerInside"
        android:padding="12dp"
        app:tint="@color/black"
        app:layout_constraintTop_toTopOf="@id/buttonBack"
        app:layout_constraintBottom_toBottomOf="@id/buttonBack"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ================= SELECTION MODE HEADER ================= -->
    <ImageButton
        android:id="@+id/buttonCloseSelection"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_back_button"
        android:src="@drawable/ic_close"
        android:contentDescription="@string/gen_activity_conversation_detail_content_description_5"
        android:scaleType="centerInside"
        android:padding="12dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/textSelectionCount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        android:text="@string/gen_activity_conversation_detail_text_6"
        android:textColor="@color/black"
        android:textSize="20sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/buttonCloseSelection"
        app:layout_constraintBottom_toBottomOf="@id/buttonCloseSelection"
        app:layout_constraintStart_toEndOf="@id/buttonCloseSelection"
        app:layout_constraintEnd_toStartOf="@id/imageStar"/>

    <ImageButton
        android:id="@+id/imageStar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="16dp"
        android:src="@drawable/ic_star"
        android:background="@android:color/transparent"
        android:contentDescription="@string/gen_activity_conversation_detail_content_description_7"
        android:scaleType="centerInside"
        android:padding="12dp"
        app:tint="#FFA500"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/buttonCloseSelection"
        app:layout_constraintBottom_toBottomOf="@id/buttonCloseSelection"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ================= MESSAGES RECYCLER VIEW ================= -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewMessages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/buttonBack"
        app:layout_constraintBottom_toTopOf="@id/bannerAdContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ================= BANNER AD ================= -->
    <FrameLayout
        android:id="@+id/bannerAdContainer"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:clipChildren="true"
        android:clipToPadding="true"
        android:tag="banner_ad_host_container"
        app:layout_constraintBottom_toTopOf="@id/layoutInput"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.gms.ads.AdView
            android:id="@+id/adViewBanner"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:adSize="BANNER"
            app:adUnitId="@string/banner_ad_unit_placeholder" />

    </FrameLayout>

    <!-- ================= INPUT AREA ================= -->
    <LinearLayout
        android:id="@+id/layoutInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:elevation="4dp"
        android:minHeight="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Scheduled Info Container (initially hidden) -->
        <LinearLayout
            android:id="@+id/layoutScheduledInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="4dp"
            android:background="#E6F0FF"
            android:visibility="gone">

            <TextView
                android:id="@+id/textScheduledInfo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/gen_activity_conversation_detail_text_8"
                android:textColor="@color/black"
                android:textSize="12sp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"/>

            <ImageButton
                android:id="@+id/buttonCancelScheduled"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_close"
                android:background="@android:color/transparent"
                android:contentDescription="@string/gen_activity_conversation_detail_content_description_9"
                android:padding="4dp"
                android:scaleType="centerInside"/>

        </LinearLayout>

        <!-- Attachments Container -->
        <HorizontalScrollView
            android:id="@+id/scrollViewAttachments"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="4dp">

            <LinearLayout
                android:id="@+id/layoutAttachments"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"/>

        </HorizontalScrollView>

        <!-- Input Row -->
        <LinearLayout
            android:id="@+id/layoutInputRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <!-- Attachment Icon -->
            <ImageButton
                android:id="@+id/imageAttachment"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_attachment"
                android:background="@android:color/transparent"
                android:contentDescription="@string/gen_activity_conversation_detail_content_description_10"
                android:scaleType="centerInside"
                android:padding="12dp"
                android:minHeight="0dp"/>

            <!-- Message Input -->
            <EditText
                android:id="@+id/editTextMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="textMultiLine"
                android:maxLines="5"
                android:minLines="1"
                android:textColor="@android:color/black"
                android:textColorHint="@color/gray_dark"
                android:hint="@string/gen_activity_conversation_detail_hint_11"
                android:textCursorDrawable="@drawable/text_cursor_drawable"
                android:textSelectHandle="@drawable/text_select_handle"
                android:textSelectHandleLeft="@drawable/text_select_handle_left"
                android:textSelectHandleRight="@drawable/text_select_handle_right"
                android:background="@drawable/bg_pill_input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:backgroundTint="@null"
                android:minHeight="0dp"/>

            <!-- Send Button -->
            <ImageButton
                android:id="@+id/buttonSend"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_send"
                android:background="@android:color/transparent"
                android:contentDescription="@string/gen_activity_conversation_detail_content_description_12"
                android:scaleType="centerInside"
                android:padding="12dp"
                android:minHeight="0dp"/>

        </LinearLayout>

        <TextView
            android:id="@+id/textReplyDisabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingStart="24dp"
            android:paddingTop="12dp"
            android:paddingEnd="24dp"
            android:paddingBottom="20dp"
            android:text="@string/cannot_reply_to_sender"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:visibility="gone"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>





