<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="32dp">

    <!-- Images ViewPager -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPagerImages"
        android:layout_width="0dp"
        android:layout_height="280dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_percent="0.85" />

    <!-- Description Text -->
    <TextView
        android:id="@+id/textDescription"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:text="See Essential Messages Instantly On The Screen Without Opening The App, Which Will Help You To Get Information Quickly.\n\nOnly some important messages will be shown on the screen. Ex: OTP messages."
        android:textColor="@color/black"
        android:textSize="16sp"
        android:fontFamily="@font/poppins"
        android:gravity="center"
        android:ellipsize="end"
        android:maxLines="5"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@+id/viewPagerImages"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scroll Dots Indicator -->
    <LinearLayout
        android:id="@+id/scrollDotsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@+id/textDescription"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/dot1"
            android:layout_width="24dp"
            android:layout_height="8dp"
            android:minWidth="24dp"
            android:minHeight="8dp"
            android:background="@drawable/dot_indicator_active"
            android:layout_marginEnd="8dp" />

        <View
            android:id="@+id/dot2"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:minWidth="8dp"
            android:minHeight="8dp"
            android:background="@drawable/dot_indicator_inactive" />

    </LinearLayout>

    <!-- Permission Heading -->
    <TextView
        android:id="@+id/textPermissionHeading"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Allow Overlay Permission For A Better Experience."
        android:textColor="@color/black"
        android:textSize="18sp"
        android:textStyle="bold"
        android:fontFamily="@font/poppins"
        android:gravity="center"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@+id/scrollDotsContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Instructions Box -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/containerInstructions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_instructions_box"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@+id/textPermissionHeading"
        app:layout_constraintBottom_toTopOf="@+id/buttonAllowPermission"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/textStep1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Step 01: Tap &quot;Enable&quot; Below"
            android:textColor="@color/primary_blue"
            android:textSize="14sp"
            android:fontFamily="@font/poppins"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/textStep2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Step 02: Find #Messages In The List"
            android:textColor="@color/primary_blue"
            android:textSize="14sp"
            android:fontFamily="@font/poppins"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@+id/textStep1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/textStep3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Step 03: Toggle The Switch To Activate It"
            android:textColor="@color/primary_blue"
            android:textSize="14sp"
            android:fontFamily="@font/poppins"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@+id/textStep2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Allow Permission Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonAllowPermission"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="12dp"
        android:text="ALLOW PERMISSION"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:fontFamily="@font/poppins"
        android:backgroundTint="@color/primary_blue"
        android:stateListAnimator="@null"
        app:cornerRadius="28dp"
        app:layout_constraintTop_toBottomOf="@+id/containerInstructions"
        app:layout_constraintBottom_toTopOf="@+id/textSettingsNote"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Settings Note Text -->
    <TextView
        android:id="@+id/textSettingsNote"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="You can disable this anytime in settings."
        android:textColor="#999999"
        android:textSize="12sp"
        android:fontFamily="@font/poppins"
        android:gravity="center"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

