<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:background="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/imageContact"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/contacts"
        app:civ_border_width="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/textContactName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="@string/gen_item_blocked_conversation_text_1"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/imageContact"
        app:layout_constraintBottom_toTopOf="@id/textSnippet"
        app:layout_constraintStart_toEndOf="@id/imageContact"
        app:layout_constraintEnd_toStartOf="@id/textUnblock"/>

    <TextView
        android:id="@+id/textSnippet"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="4dp"
        android:text="@string/gen_item_blocked_conversation_text_2"
        android:textColor="@color/gray_dark"
        android:textSize="14sp"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintTop_toBottomOf="@id/textContactName"
        app:layout_constraintBottom_toBottomOf="@id/imageContact"
        app:layout_constraintStart_toEndOf="@id/imageContact"
        app:layout_constraintEnd_toStartOf="@id/textUnblock"/>

    <TextView
        android:id="@+id/textUnblock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/gen_item_blocked_conversation_text_3"
        android:textColor="#0C56CF"
        android:textSize="16sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:background="#9A999F"
        app:layout_constraintTop_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>


