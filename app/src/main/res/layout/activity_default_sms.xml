<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="28dp">

            <TextView
                android:id="@+id/textBrandTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="@string/default_sms_brand_title"
                android:textColor="#171727"
                android:textSize="34sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/imagePhone"
                android:layout_width="270dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:adjustViewBounds="true"
                android:contentDescription="@string/default_sms_illustration"
                android:scaleType="fitCenter"
                android:src="@drawable/sms" />

            <TextView
                android:id="@+id/textIntro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/poppins"
                android:gravity="center"
                android:text="@string/default_sms_intro"
                android:textColor="#666676"
                android:textSize="17sp" />

            <TextView
                android:id="@+id/textHeading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/poppins"
                android:gravity="center"
                android:lineSpacingExtra="2dp"
                android:text="@string/default_sms_heading"
                android:textColor="#171727"
                android:textSize="25sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical"
                android:paddingStart="34dp"
                android:paddingEnd="20dp">

                <TextView
                    android:id="@+id/textBulletOne"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/default_sms_bullet_one"
                    android:textColor="#555566"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/textBulletTwo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:fontFamily="@font/poppins"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/default_sms_bullet_two"
                    android:textColor="#555566"
                    android:textSize="16sp" />
            </LinearLayout>

            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/shimmerSetDefault"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="32dp"
                app:shimmer_auto_start="false"
                app:shimmer_base_alpha="0.08"
                app:shimmer_direction="left_to_right"
                app:shimmer_duration="1300"
                app:shimmer_highlight_alpha="1"
                app:shimmer_intensity="0.35"
                app:shimmer_dropoff="0.2">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonSetDefault"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:backgroundTint="@color/button_primary"
                    android:elevation="6dp"
                    android:fontFamily="@font/poppins"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:tag="exclude_from_theme_textcolor"
                    android:text="@string/set_default_sms"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="29dp" />

            </com.facebook.shimmer.ShimmerFrameLayout>

            <TextView
                android:id="@+id/textHelpPrompt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:fontFamily="@font/poppins"
                android:gravity="center"
                android:text="@string/default_sms_help_prompt"
                android:textColor="#4F4F60"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/textHelpLink"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/poppins"
                android:gravity="center"
                android:text="@string/default_sms_help_link"
                android:textColor="@color/button_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
