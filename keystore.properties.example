# Copy to keystore.properties (never commit) and fill in your release keystore.
# Then: ./gradlew assembleRelease
# Output: app/build/outputs/apk/release/app-release.apk
#
# IMPORTANT for sharing APK via WhatsApp/Drive/Discord:
# The APK must be signed with v1 + v2 (this Gradle config enables both).
# v2-only APKs often install via adb but fail with "App not installed" when opened from chat apps.

storeFile=C:/path/to/your-release-key.jks
storePassword=your-store-password
keyAlias=your-key-alias
keyPassword=your-key-password
