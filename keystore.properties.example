# Copy to keystore.properties (never commit) and fill in your release keystore.
# Then: ./gradlew assembleRelease
# Output: app/build/outputs/apk/release/app-release.apk (signed, sideload-safe)

storeFile=C:/path/to/your-release-key.jks
storePassword=your-store-password
keyAlias=your-key-alias
keyPassword=your-key-password
